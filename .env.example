# Server Configuration
PORT=8080
NODE_ENV=production
SERVICE_NAME=finsightiq-api

# Database
DATABASE_URL=postgresql://finsightiq:password@localhost:5432/finsightiq

# Redis (optional - Railway sets this automatically when Redis plugin is attached)
REDIS_URL=

# AI Configuration
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4000
CLAUDE_TEMPERATURE_EXTRACT=0.1
CLAUDE_TEMPERATURE_NARRATIVE=0.3
CLAUDE_MAX_RETRIES=2

# Document Processing
MAX_FILE_SIZE_MB=30
UPLOAD_TEMP_DIR=/tmp/finsightiq-uploads
DOCUMENT_EXPIRY_HOURS=72

# Cache
ANALYSIS_CACHE_TTL_HOURS=24
REDIS_HOT_CACHE_TTL_HOURS=2

# Features
ENABLE_OCR=true
ENABLE_BATCH=true
ENABLE_WEBHOOKS=true

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
