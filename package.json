    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1",
    "redis": "^5.11.0",
    "sharp": "^0.33.2",
    "swagger-ui-express": "^5.0.0",
    "tesseract.js": "^5.0.5",
